# ============================================================
# ResilienceAI — Shared Environment Configuration
# Copy this file to .env and update values for your deployment.
# ============================================================

# --- MongoDB (replica set required for Change Streams) ---
MONGO_URI=mongodb://localhost:27017/resilienceai?replicaSet=rs0

# --- Redis (BullMQ backing store) ---
REDIS_URI=redis://localhost:6379

# --- Qdrant (vector similarity search for runbooks) ---
QDRANT_URI=http://localhost:6333
QDRANT_API_KEY=

# --- JWT Secret (shared auth across services) ---
JWT_SECRET=change-this-in-production-use-at-least-256-bits

# --- Service Ports ---
WEBHOOKS_GATEWAY_PORT=4000
AGENT_ENGINE_PORT=8000
DASHBOARD_PORT=5173

# --- Inter-Service URLs ---
AGENT_ENGINE_URL=http://localhost:8000
WEBHOOKS_GATEWAY_URL=http://localhost:4000

# --- LLM Provider (OpenAI-compatible API) ---
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# --- Embedding Provider (for Qdrant runbook indexing) ---
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# --- Alert Deduplication Window (seconds) ---
DEDUP_WINDOW_SECONDS=10
